{
  "name": "agent-delegation-link",
  "version": "0.3.0-alpha.1",
  "description": "Task-scoped delegation links for user-owned Codex and Claude Code agents.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "files": [
    "dist",
    ".agents/skills/delegate-to-agent",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "docs"
  ],
  "bin": {
    "adl": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "demo": "tsx examples/local-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.0",
    "ws": "^8.18.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
